{
    "name": "maskulabs/inertia-yii",
    "description": "Yii3 integration for Inertia.js v3 with server-side rendering support, middleware, validation error handling, session and flash adapters, and Vite asset integration.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "yii",
        "yii3",
        "inertia",
        "inertiajs",
        "inertia.js"
    ],
    "homepage": "https://github.com/maskulabs/inertia-yii",
    "support": {
        "issues": "https://github.com/maskulabs/inertia-yii/issues",
        "source": "https://github.com/maskulabs/inertia-yii"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.5",
        "maskulabs/inertia-psr": "^3.0",
        "yiisoft/assets": "^5.1",
        "yiisoft/csrf": "^2.2",
        "yiisoft/data-response": "^2.2",
        "yiisoft/definitions": "^3.4",
        "yiisoft/http-middleware": "^1.2",
        "yiisoft/injector": "^1.2",
        "yiisoft/input-http": "^1.0",
        "yiisoft/request-provider": "^1.3",
        "yiisoft/session": "^3.0",
        "yiisoft/validator": "^2.5",
        "yiisoft/yii-view-renderer": "^7.4"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94",
        "httpsoft/http-message": "^1.1",
        "phpunit/phpunit": "^12.5",
        "rector/rector": "^2.3",
        "vimeo/psalm": "^6.15",
        "yiisoft/code-style": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "MaskuLabs\\InertiaYii\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MaskuLabs\\InertiaYii\\Tests\\": "tests/"
        }
    },
    "extra": {
        "config-plugin-options": {
            "source-directory": "config"
        },
        "config-plugin": {
            "params": "params.php",
            "di-web": "di-web.php"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "infection/extension-installer": true,
            "composer/package-versions-deprecated": true
        }
    },
    "scripts": {
        "test": "phpunit tests",
        "cs": "php-cs-fixer fix --dry-run --diff --verbose",
        "cs-fix": "php-cs-fixer fix",
        "rector": "rector process --dry-run",
        "rector-fix": "rector process",
        "psalm": "psalm"
    }
}
